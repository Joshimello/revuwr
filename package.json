{
  "name": "with-svelte",
  "devDependencies": {
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.2",
    "turbo": "^2.9.16",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.5",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write ."
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "docs/*"
  ]
}
